# Production Environment Variables for Hugging Face Spaces Deployment
# Copy these to HF Spaces: Settings > Repository Secrets

# ============================================================
# OpenRouter (LLM Provider)
# ============================================================
OPENROUTER_API_KEY=sk-or-v1-...  # Get from: https://openrouter.ai/keys
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openrouter/owl-alpha

# ============================================================
# Cohere (Embeddings Provider)
# ============================================================
COHERE_API_KEY=hJUB1...  # Get from: https://dashboard.cohere.com/
COHERE_EMBEDDING_MODEL=embed-english-v3.0

# ============================================================
# Qdrant Cloud (Vector Database)
# ============================================================
QDRANT_URL=https://your-cluster-id.gcp.cloud.qdrant.io
QDRANT_API_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
QDRANT_COLLECTION_NAME=humanoid_robotics_book

# ============================================================
# Neon Postgres (User Data & Conversations)
# ============================================================
NEON_DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# ============================================================
# API Configuration
# ============================================================
CORS_ORIGINS=https://anusbutt.github.io,https://anusbutt-rag-chatbot.hf.space
API_RATE_LIMIT=100

# ============================================================
# NOTES:
# ============================================================
# 1. Never commit .env files to git (already in .gitignore)
# 2. Add ALL variables to HF Spaces Settings > Repository Secrets
# 3. Hugging Face Spaces uses port 7860 (hardcoded in Dockerfile)
# 4. Update CORS_ORIGINS with your actual HF Spaces URL after creation
# 5. OpenRouter free models use :free suffix (20 req/min, 200/day)
# 6. Other good free models: deepseek/deepseek-r1:free, openai/gpt-oss-120b:free
